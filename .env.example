APP_NAME=project_agent
DATABASE_URL=postgresql+asyncpg://agent:agent@localhost:5432/agent
REDIS_URL=redis://localhost:6379/0

# LLM config — copy from my-agent/.env (DeepSeek-compatible endpoint)
ANTHROPIC_API_KEY=your-key-here
ANTHROPIC_BASE_URL=https://your-deepseek-endpoint
MODEL_ID=your-model-id

# Embedding — SiliconFlow bge-m3 (free tier, OpenAI-compatible)
# Register at siliconflow.cn to get a free API key
EMBEDDING_API_KEY=sk-your-siliconflow-key
EMBEDDING_BASE_URL=https://api.siliconflow.cn/v1
EMBEDDING_MODEL=BAAI/bge-m3
EMBEDDING_DIM=1024
